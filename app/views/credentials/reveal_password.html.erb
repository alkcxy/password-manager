<% frame_id = params[:mobile].present? ? "password_m_#{@credential.id}" : "password_#{@credential.id}" %>
<%= turbo_frame_tag frame_id do %>
  <%= link_to hide_password_credential_path(@credential, mobile: params[:mobile]), class: "btn btn-sm btn-outline-secondary me-1", title: "Nascondi", aria: { label: "Nascondi" } do %>
    <i class="bi bi-eye-slash"></i><%= " Nascondi" if params[:mobile].present? %>
  <% end %>
  <!--email_off--><code><%= @credential.password %></code><!--/email_off-->
<% end %>
