<h1>Credenziali</h1>

<%= form_tag '/credentials', method: :get, class: "form-inline" do %>
  <div class="form-group mx-sm-3 mb-2">
    <%= label_tag :q, "Parola chiave", class: "sr-only" %>
    <%= search_field_tag :q, params[:q], class: "form-control", placeholder: "Parola chiave" %>
  </div>
  <%= button_tag class: "btn btn-primary mb-2" do %><i class="bi bi-search"></i> Cerca<% end %>
<% end %>

<%# Mobile card list — hidden on md+ %>
<div class="d-lg-none">
  <% @credentials.each do |credential| %>
    <div class="card mb-2">
      <div class="card-body py-2 px-3">
        <div class="d-flex justify-content-between align-items-center mb-1">
          <strong><%= credential.name %></strong>
          <div class="d-flex gap-1">
            <% if credential.note.present? %>
              <button type="button"
                      class="btn btn-sm btn-outline-secondary"
                      data-bs-toggle="popover"
                      data-bs-trigger="click"
                      data-bs-placement="left"
                      data-bs-content="<%= h credential.note %>"
                      title="Note"
                      aria-label="Note">
                <i class="bi bi-sticky"></i>
              </button>
            <% end %>
            <%= link_to edit_credential_path(credential), class: "btn btn-sm btn-outline-secondary", title: "Modifica", aria: { label: "Modifica" } do %>
              <i class="bi bi-pencil"></i>
            <% end %>
            <%= link_to credential, class: "btn btn-sm btn-outline-danger", title: "Cancella", aria: { label: "Cancella" },
                  data: { turbo_method: :delete, turbo_confirm: 'Sicuro? Non sarà più possibile recuperare le credenziali!' } do %>
              <i class="bi bi-trash"></i>
            <% end %>
          </div>
        </div>
        <div class="d-flex flex-wrap gap-1">
          <button data-controller="clipboard"
                  data-clipboard-url-value="<%= copy_password_credential_path(credential) %>"
                  data-action="click->clipboard#copy"
                  class="btn btn-sm btn-outline-secondary"
                  type="button"
                  aria-label="Copia password"
                  title="Copia password"><i class="bi bi-clipboard"></i> Password</button>
          <%= turbo_frame_tag "password_m_#{credential.id}" do %>
            <%= link_to reveal_password_credential_path(credential, mobile: 1), class: "btn btn-sm btn-outline-secondary", title: "Mostra", aria: { label: "Mostra" } do %><i class="bi bi-eye"></i> Mostra<% end %>
          <% end %>
          <button data-controller="clipboard"
                  data-clipboard-text-value="<%= credential.username %>"
                  data-action="click->clipboard#copy"
                  class="btn btn-sm btn-outline-secondary"
                  type="button"
                  aria-label="Copia username"
                  title="Copia username"><i class="bi bi-clipboard"></i> Username</button>
          <button data-controller="clipboard"
                  data-clipboard-text-value="<%= credential.url %>"
                  data-action="click->clipboard#copy"
                  class="btn btn-sm btn-outline-secondary"
                  type="button"
                  aria-label="Copia url"
                  title="Copia url"><i class="bi bi-clipboard"></i> URL</button>
          <%= link_to credential.url, target: "_blank", rel: "noopener noreferrer",
                class: "btn btn-sm btn-outline-secondary", title: "Apri url", aria: { label: "Apri url" } do %>
            <i class="bi bi-box-arrow-up-right"></i>
          <% end %>
        </div>
      </div>
    </div>
  <% end %>
</div>

<%# Desktop table — hidden on mobile %>
<div class="d-none d-lg-block">
  <div class="table-responsive">
  <table class="table" style="table-layout: fixed; width: 100%">
    <thead>
      <tr>
        <th style="width: 12%">Name</th>
        <th style="width: 20%">Username</th>
        <th style="width: 18%">Url</th>
        <th style="width: 28%">Password</th>
        <th style="width: 22%"></th>
      </tr>
    </thead>

    <tbody>
      <% @credentials.each do |credential| %>
        <tr>
          <td><%= credential.name %></td>
          <td>
            <button data-controller="clipboard"
                    data-clipboard-text-value="<%= credential.username %>"
                    data-action="click->clipboard#copy"
                    class="btn btn-sm btn-outline-secondary me-1"
                    type="button"
                    aria-label="Copia username"
                    title="Copia username"><i class="bi bi-clipboard"></i></button>
            <%= credential.username %>
          </td>
          <td>
            <div class="d-flex align-items-center" style="min-width: 0">
              <button data-controller="clipboard"
                      data-clipboard-text-value="<%= credential.url %>"
                      data-action="click->clipboard#copy"
                      class="btn btn-sm btn-outline-secondary me-1 flex-shrink-0"
                      type="button"
                      aria-label="Copia url"
                      title="Copia url"><i class="bi bi-clipboard"></i></button>
              <span style="overflow: hidden; text-overflow: ellipsis; white-space: nowrap; min-width: 0"><%= link_to credential.url, credential.url, target: "_blank", rel: "noopener noreferrer" %></span>
            </div>
          </td>
          <td>
            <button data-controller="clipboard"
                    data-clipboard-url-value="<%= copy_password_credential_path(credential) %>"
                    data-action="click->clipboard#copy"
                    class="btn btn-sm btn-outline-secondary me-1"
                    type="button"
                    aria-label="Copia password"
                    title="Copia password"><i class="bi bi-clipboard"></i></button>
            <%= turbo_frame_tag "password_#{credential.id}" do %>
              <%= link_to reveal_password_credential_path(credential), class: "btn btn-sm btn-outline-secondary", title: "Mostra", aria: { label: "Mostra" } do %><i class="bi bi-eye"></i><% end %>
            <% end %>
          </td>
          <td class="text-nowrap">
            <% if credential.note.present? %>
              <button type="button"
                      class="btn btn-sm btn-outline-secondary"
                      data-bs-toggle="popover"
                      data-bs-trigger="click"
                      data-bs-placement="left"
                      data-bs-content="<%= h credential.note %>"
                      title="Note"
                      aria-label="Note">
                <i class="bi bi-sticky"></i>
              </button>
            <% end %>
            <%= link_to edit_credential_path(credential),
                  class: "btn btn-sm btn-outline-secondary ms-1",
                  title: "Modifica",
                  aria: { label: "Modifica" } do %>
              <i class="bi bi-pencil"></i>
            <% end %>
            <%= link_to credential,
                  class: "btn btn-sm btn-outline-danger ms-1",
                  title: "Cancella",
                  aria: { label: "Cancella" },
                  data: { turbo_method: :delete, turbo_confirm: 'Sicuro? Non sarà più possibile recuperare le credenziali!' } do %>
              <i class="bi bi-trash"></i>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
  </div>
</div>

<div class="d-flex flex-column align-items-center my-3">
  <span class="text-muted small mb-1"><%= page_entries_info @credentials %></span>
  <%= paginate @credentials %>
</div>
<div class="btn-group" role="group" aria-label="Strumenti">
  <%= link_to new_credential_path, class: "btn btn-primary" do %><i class="bi bi-plus-circle"></i> Nuova Credenziale<% end %>
  <%= link_to welcome_path, class: "btn btn-primary" do %><i class="bi bi-house"></i> Home<% end %>
</div>
