
<p>
  <strong>Name:</strong>
  <%= @credential.name %>
</p>

<p>
  <strong>Username:</strong>
  <%= @credential.username %>
  <button data-controller="clipboard"
          data-clipboard-text-value="<%= @credential.username %>"
          data-action="click->clipboard#copy"
          class="btn btn-sm btn-outline-secondary ms-1"
          type="button"
          aria-label="Copia username"
          title="Copia username"><i class="bi bi-clipboard"></i></button>
</p>

<p>
  <strong>Password:</strong>
  <%= turbo_frame_tag "password_#{@credential.id}" do %>
    <%= link_to reveal_password_credential_path(@credential), class: "btn btn-sm btn-outline-secondary", title: "Mostra", aria: { label: "Mostra" } do %><i class="bi bi-eye"></i><% end %>
  <% end %>
  <button data-controller="clipboard"
          data-clipboard-url-value="<%= copy_password_credential_path(@credential) %>"
          data-action="click->clipboard#copy"
          class="btn btn-sm btn-outline-secondary ms-1"
          type="button"
          aria-label="Copia password"
          title="Copia password"><i class="bi bi-clipboard"></i></button>
</p>

<p>
  <strong>Url:</strong>
  <%= @credential.url %>
</p>

<p>
  <strong>Note:</strong>
  <%= @credential.note %>
</p>
<br />
<div class="btn-group" role="group" aria-label="Strumenti">
  <%= link_to edit_credential_path(@credential), class: "btn btn-primary" do %><i class="bi bi-pencil"></i> Modifica<% end %>
  <%= link_to credentials_path, class: "btn btn-primary" do %><i class="bi bi-key"></i> Credenziali<% end %>
</div>
